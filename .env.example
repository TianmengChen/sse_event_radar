APP_NAME=sse-event-radar
APP_ENV=dev
LOG_LEVEL=INFO

DATA_DIR=./data
DATABASE_URL=sqlite:///./data/db/sse_event_radar.sqlite3

# Collector intervals
QUOTE_POLL_SECONDS=60
ANNOUNCEMENT_POLL_MINUTES=5
STOCK_MASTER_REFRESH_HOUR=17

# AKShare safety
AKSHARE_RATE_LIMIT_SECONDS=3

# Later: LLM module
ENABLE_LLM=false
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Later: notification
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ServerChan notification
ENABLE_SERVERCHAN=false
SERVERCHAN_SENDKEY=

# Feishu custom bot notification
ENABLE_FEISHU_BOT=false
FEISHU_BOT_WEBHOOK=
FEISHU_BOT_SECRET=